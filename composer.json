{
  "name": "code-pilgrimz/symfony-api",
  "type": "project",
  "require": {
    "php": ">=8.2",
    "symfony/framework-bundle": "^7.0",
    "symfony/console": "^7.0",
    "symfony/dotenv": "^7.0",
    "symfony/runtime": "^7.0",
    "symfony/yaml": "^7.0",
    "doctrine/orm": "^3.0",
    "doctrine/doctrine-bundle": "^2.11",
    "symfony/validator": "^7.0",
    "symfony/serializer": "^7.0"
  },
  "require-dev": { "phpunit/phpunit": "^10.5", "symfony/test-pack": "^1.0" },
  "autoload": { "psr-4": { "App\\": "src/" } },
  "autoload-dev": { "psr-4": { "App\\Tests\\": "tests/" } }
}
